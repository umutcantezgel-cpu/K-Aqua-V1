# ── K-Aqua environment ──────────────────────────────────────────
# Copy to .env.local and fill in. The current prototype needs NONE of these
# to build — they are forward-looking for Phase 2 (CMS, forms, analytics).

# Public site URL (used by sitemap.ts, robots.ts, OG images, hreflang)
NEXT_PUBLIC_SITE_URL=https://www.k-aqua.de

# Phase 2 — Headless CMS (optional; geo + product data are static TS modules today)
# CMS_API_URL=
# CMS_API_TOKEN=

# Phase 2 — RFQ / contact form delivery (today the form opens a mailto:)
# CONTACT_INBOX=info@k-aqua.de
# RESEND_API_KEY=

# Phase 2 — Analytics (none wired in the prototype)
# NEXT_PUBLIC_ANALYTICS_ID=
